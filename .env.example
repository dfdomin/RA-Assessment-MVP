# Supabase (scripts/seed_consolidators_from_mapping.py, supabase_snapshot.py)
# SUPABASE_URL=https://whjjervbojyktkhvvmte.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Application environment: development | production
APP_ENV=development

# PostgreSQL async connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ra_user:ra_pass@localhost/ra_assessment

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# JWT algorithm (do not change)
ALGORITHM=HS256

# JWT lifetime in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS allowed origins (comma-separated list in JSON array format)
ALLOWED_ORIGINS=["http://localhost:8000"]

# Microsoft Entra ID / Azure AD (optional — leave empty to disable OIDC)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# Gmail SMTP app password (optional — for future email notifications)
GMAIL_APP_PASSWORD=

# GPG recipient for encrypted backups (optional)
BACKUP_GPG_RECIPIENT=

# rclone remote destination for encrypted backups (optional)
BACKUP_RCLONE_REMOTE=r2:ra-assessment-backups/

# PostgreSQL local para tests E2E — requiere Docker Desktop/Engine.
# Levantar con: docker compose up -d db
# Luego ejecutar: pytest tests/ -m pg -v
# Solo para datos descartables/test-owned; no usar con datos reales.
TEST_PG_URL=postgresql+asyncpg://ra:local_only@localhost:5432/ra_test
